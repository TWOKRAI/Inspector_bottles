# Makefile — шаблон для нового проекта
# Адаптировать: переменная PACKAGE (главный пакет)

.DEFAULT_GOAL := help
SHELL := /bin/bash

# ── Пути ──
PYTHON := python
PYTEST := $(PYTHON) -m pytest
RUFF := ruff
MYPY := mypy
BANDIT := bandit

PACKAGE := PROJECT_NAME                         # ← замени
DIAGRAMS_DIR := docs/diagrams

# ── Быстрые проверки ──

.PHONY: lint
lint: ## Ruff lint
	$(RUFF) check .

.PHONY: lint-fix
lint-fix: ## Ruff lint + автофикс
	$(RUFF) check --fix .
	$(RUFF) format .

.PHONY: typecheck
typecheck: ## mypy (gradual)
	$(MYPY) $(PACKAGE) --ignore-missing-imports

.PHONY: security
security: ## bandit
	$(BANDIT) -r $(PACKAGE) -c pyproject.toml -q

.PHONY: check
check: lint typecheck security ## ruff + mypy + bandit

# ── Тесты ──

.PHONY: test
test: ## pytest с coverage
	$(PYTEST) --cov=$(PACKAGE) --cov-report=term-missing --cov-config=pyproject.toml

.PHONY: test-fast
test-fast: ## pytest без coverage
	$(PYTEST)

# ── Quality gate ──

.PHONY: gate
gate: check test ## Полный gate: lint + types + security + tests

# ── Диаграммы ──

.PHONY: diagrams
diagrams: diagrams-classes diagrams-deps ## Регенерация всех диаграмм

.PHONY: diagrams-classes
diagrams-classes: ## UML классов через pyreverse
	@mkdir -p $(DIAGRAMS_DIR)/classes
	pyreverse -o puml -p Project $(PACKAGE) -d $(DIAGRAMS_DIR)/classes/ 2>/dev/null || \
		echo "[SKIP] pyreverse не установлен — uv sync --group diagrams"

.PHONY: diagrams-deps
diagrams-deps: ## Граф зависимостей через pydeps
	@mkdir -p $(DIAGRAMS_DIR)/deps
	pydeps $(PACKAGE) -o $(DIAGRAMS_DIR)/deps/$(PACKAGE).svg --cluster --max-bacon 2 --no-show 2>/dev/null || \
		echo "[SKIP] pydeps не установлен или Graphviz не в PATH"

# ── Очистка ──

.PHONY: clean
clean: ## Удалить Python-кэши
	find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
	find . -type d -name .pytest_cache -exec rm -rf {} + 2>/dev/null || true
	find . -type d -name .mypy_cache -exec rm -rf {} + 2>/dev/null || true
	find . -name "*.pyc" -delete 2>/dev/null || true
	find . -name ".coverage" -delete 2>/dev/null || true
	@echo "Кэши очищены"

# ── Справка ──

.PHONY: help
help: ## Показать эту справку
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | \
		awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-18s\033[0m %s\n", $$1, $$2}'
