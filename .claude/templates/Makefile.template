# Makefile — single entry point for development tasks
# Toolchain: uv + ruff + pyright + pytest

.DEFAULT_GOAL := help
SHELL := /bin/bash

PACKAGE := {{PACKAGE}}
UV := uv
RUN := $(UV) run

# ── Setup ─────────────────────────────────────────────────────────────────────

.PHONY: install
install: ## Install project + dev deps + pre-commit hooks
	$(UV) sync --group dev
	$(RUN) pre-commit install
	$(RUN) pre-commit install --hook-type pre-push

.PHONY: update
update: ## Update all deps to latest compatible versions
	$(UV) sync --upgrade --group dev

# ── Quality gates ─────────────────────────────────────────────────────────────

.PHONY: lint
lint: ## Ruff lint (no fixes)
	$(RUN) ruff check .

.PHONY: format
format: ## Ruff format + lint fixes
	$(RUN) ruff check --fix .
	$(RUN) ruff format .

.PHONY: typecheck
typecheck: ## Pyright type check
	$(RUN) pyright src

.PHONY: check
check: lint typecheck ## Full static check (lint + types)

# ── Tests ─────────────────────────────────────────────────────────────────────

.PHONY: test
test: ## Run pytest with coverage
	$(RUN) pytest --cov=$(PACKAGE) --cov-report=term-missing

.PHONY: test-fast
test-fast: ## Run pytest without coverage
	$(RUN) pytest

.PHONY: test-xml
test-xml: ## Run pytest with coverage.xml (Codecov / IDE / CI artifacts)
	$(RUN) pytest --cov=$(PACKAGE) --cov-report=xml --cov-report=term

.PHONY: test-watch
test-watch: ## Re-run tests on file changes (needs pytest-watch)
	$(RUN) ptw -- --tb=short

# ── Gate ──────────────────────────────────────────────────────────────────────

.PHONY: gate
gate: check test ## Full gate: lint + types + tests (run before push)

.PHONY: pre-commit
pre-commit: ## Run all pre-commit hooks on all files
	$(RUN) pre-commit run --all-files

# ── Cleanup ───────────────────────────────────────────────────────────────────

.PHONY: clean
clean: ## Remove caches and build artifacts
	find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
	find . -type d -name .pytest_cache -exec rm -rf {} + 2>/dev/null || true
	find . -type d -name .ruff_cache -exec rm -rf {} + 2>/dev/null || true
	find . -type d -name .pyright_cache -exec rm -rf {} + 2>/dev/null || true
	find . -name "*.pyc" -delete 2>/dev/null || true
	find . -name ".coverage" -delete 2>/dev/null || true
	rm -rf build/ dist/ *.egg-info htmlcov/
	@echo "Caches cleaned"

# ── Help ──────────────────────────────────────────────────────────────────────

.PHONY: help
help: ## Show this help
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | \
		awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-15s\033[0m %s\n", $$1, $$2}'
