{
  "name": "mcp-qt",
  "version": "0.4.0",
  "description": "Qt/PyQt GUI runtime inspection",
  "mcpServers": {
    "qt-mcp": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/0xCarbon/qt-mcp",
        "python",
        "-m",
        "qt_mcp.server"
      ],
      "env": {
        "QT_MCP_PROBE_HOST": "127.0.0.1",
        "QT_MCP_PROBE_PORT": "9142"
      }
    }
  }
}
