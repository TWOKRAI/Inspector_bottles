{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Agent",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(cat *.md)",
      "Bash(cat *.toml)",
      "Bash(cat *.json)",
      "Bash(echo *)",
      "Bash(mkdir -p *)",
      "Bash(make *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git blame*)",
      "Bash(git add *)",
      "Bash(git commit -m *)",
      "Bash(git commit -am *)",
      "Bash(git branch*)",
      "Bash(git checkout -b *)",
      "Bash(git checkout *.md)",
      "Bash(git stash list*)",
      "Bash(git fetch*)",
      "Bash(ollama *)",
      "Bash(curl http://localhost:11434*)",
      "Bash(curl -s http://localhost:11434*)",
      "Bash(curl -s --max-time * http://localhost:11434*)",
      "Bash(sentrux *)",
      "Bash(qex *)",
      "Bash(claude-kit *)",
      "Bash(claude-kit)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git cherry-pick *)",
      "Bash(git reset *)",
      "Bash(git revert *)",
      "Bash(git stash *)",
      "Bash(git tag *)",
      "Bash(git remote *)",
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(chmod *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(npm install *)",
      "Bash(npm i *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(brew install *)",
      "Bash(apt *)",
      "Bash(winget *)",
      "Bash(docker *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push --no-verify *)",
      "Bash(git commit --no-verify *)",
      "Bash(git commit -n *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- *)",
      "Bash(git restore --source*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -f*)",
      "Bash(git clean -x*)",
      "Bash(git update-ref -d *)",
      "Bash(git filter-branch *)",
      "Bash(git filter-repo *)",
      "Bash(mkfs*)",
      "Bash(mkfs.* *)",
      "Bash(dd if=*)",
      "Bash(dd of=/dev/*)",
      "Bash(:() { :|: & };:*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)",
      "Write(**/.env)",
      "Write(**/.env.local)",
      "Write(**/.env.*.local)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/id_rsa)",
      "Write(**/id_ed25519)",
      "Edit(**/.env)",
      "Edit(**/.env.local)",
      "Edit(**/.env.*.local)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/id_rsa)",
      "Edit(**/id_ed25519)"
    ]
  },
  "env": {
    "MCP_TIMEOUT": "7200000",
    "MCP_TOOL_TIMEOUT": "7200000"
  },
  "alwaysThinkingEnabled": true,
  "preferredLanguage": "ru",
  "statusLine": {
    "type": "command",
    "command": "printf 'branch: %s | ollama: %s' \"$(git branch --show-current 2>/dev/null)\" \"$(curl -s --max-time 1 http://localhost:11434/ 2>/dev/null | grep -q running && echo UP || echo DOWN)\""
  }
}
