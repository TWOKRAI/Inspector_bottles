# EditorConfig — cross-IDE consistent formatting
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false   # markdown uses double-space for line break

[*.{yaml,yml,toml,json}]
indent_size = 2

[*.{js,ts,jsx,tsx,html,css,scss}]
indent_size = 2

[Makefile]
indent_style = tab

[*.sh]
indent_size = 4
end_of_line = lf
