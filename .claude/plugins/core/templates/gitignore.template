.mcp.json
# Native subagent-memory: the `project` scope (.claude/agent-memory/) is
# intentionally TRACKED — curated, version-controlled team knowledge, like
# .claude/memory/. Only the `local` scope below is ignored.
.claude/agent-memory-local/

# ─── claude-kit backup / temp artifacts ───────────────────────────────────────
# Manual unpacks of `claude-kit-claude plugin upgrade` backups (tar.gz) and the optional
# `--backup-dir <path>` target. Never commit — these contain prior-state
# snapshots of .claude/ that are noisy and large.
.backup_tmp/
.claude/_backups/

# ─── External git-managed plugins ─────────────────────────────────────────────
# Cloned β-plugins; re-cloned from enabled.yaml source+sha on a new machine.
# Never track foreign code — the lockfile declaration is sufficient.
.claude/plugins/_external/

# ─── MCP servers — local state / caches (per-project, never share) ────────────
# serena LSP indexer — keeps its memory + cache here
.serena/
# qex semantic search — local index (also lives in ~/.qex/, but project-local
# launches may drop a folder here)
.qex/
.claude/.qex/
# sentrux — only the binary cache; rules.toml IS tracked
.sentrux/cache/

# ─── Generated artifacts (regenerate via make) ────────────────────────────────
docs/diagrams/classes/*.puml
docs/diagrams/deps/*.svg
# Manual diagrams (.mmd, .drawio) are tracked — they're source files
