// Append this block to your project's .mcp.json under "mcpServers".
// Portable across Windows / macOS / Linux — uses `uv tool run` to invoke
// python from the `graphifyy` tool environment (no global install needed).
//
// Prerequisites:
//   1. `uv tool install graphifyy` (PyPI package, note the double-y)
//   2. Run the /graphify skill first to create `graphify-out/graph.json`
//      (MCP server only SERVES the graph; it does not build it).
// Strip the comments before merging (JSON doesn't allow comments).
{
  "graphify": {
    "command": "uv",
    "args": ["tool", "run", "--from", "graphifyy", "python", "-m", "graphify.serve", "graphify-out/graph.json"]
  }
}
