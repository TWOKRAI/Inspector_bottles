// Append this block to your project's .mcp.json under "mcpServers".
// Portable across Windows / macOS / Linux — uses `uvx` (ships with uv).
//
// Prerequisite: install the language server for your primary language
// (Pyright for Python, rust-analyzer for Rust, etc.). See SETUP_GUIDE.md step 2.
//
// Strip the comments before merging (JSON doesn't allow comments).
{
  "serena": {
    "command": "uvx",
    "args": [
      "--from", "serena-agent",
      "serena-mcp-server",
      "--context", "claude-code",
      "--project", "."
    ]
  }
}
