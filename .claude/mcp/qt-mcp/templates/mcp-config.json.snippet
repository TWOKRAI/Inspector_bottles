// Append this block to your project's .mcp.json under "mcpServers".
// Portable across Windows / macOS / Linux — uses `uv run` to resolve venv.
//
// Strip the comments before merging (JSON doesn't allow comments).
{
  "qt-mcp": {
    "command": "uv",
    "args": ["run", "--", "python", "-m", "qt_mcp.server"],
    "env": {
      "QT_MCP_PROBE_HOST": "127.0.0.1",
      "QT_MCP_PROBE_PORT": "9142"
    }
  }
}
