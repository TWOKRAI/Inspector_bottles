{
  "permissions": {
    "allow": [
      "Bash(ruff *)",
      "Bash(pytest *)",
      "Bash(mypy *)",
      "Bash(git *)",
      "Bash(docker ps *)",
      "Bash(docker logs *)",
      "Bash(docker start *)",
      "Bash(docker compose *)",
      "Bash(docker-compose *)",
      "Bash(docker inspect *)",
      "Bash(ollama *)",
      "Bash(python *)",
      "Bash(uv *)",
      "Bash(pip *)",
      "Bash(curl http://localhost*)",
      "Bash(curl -s http://localhost*)",
      "Bash(curl -X DELETE http://localhost:6333*)",
      "Bash(curl -X PUT http://localhost:6333*)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(docker rm *)",
      "Bash(docker rmi *)",
      "Bash(docker stop *)",
      "Bash(docker kill *)",
      "Bash(docker system *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(git clean -f *)",
      "Bash(docker system prune *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-safe-command.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/autoformat-python.sh",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": false,
  "preferredLanguage": "ru",
  "statusLine": {
    "type": "command",
    "command": "printf 'branch: %s | qdrant: %s' \"$(git branch --show-current 2>/dev/null)\" \"$(docker ps --filter name=qdrant --filter status=running --format '{{.Names}}' 2>/dev/null | grep -q qdrant && echo UP || echo DOWN)\""
  }
}