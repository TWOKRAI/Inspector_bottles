{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Agent",

      "Bash(ruff *)",
      "Bash(pytest *)",
      "Bash(mypy *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(uv run *)",
      "Bash(uv sync*)",

      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(git stash*)",
      "Bash(git merge *)",

      "Bash(ollama *)",
      "Bash(curl http://localhost:11434*)",
      "Bash(curl -s http://localhost:11434*)",
      "Bash(curl -s --max-time * http://localhost:11434*)",

      "Bash(sentrux *)",
      "Bash(qex *)",

      "Bash(mkdir -p *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(cat *.toml)",
      "Bash(cat *.md)",
      "Bash(cat *.json)",
      "Bash(which *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cp *)",
      "Bash(echo *)",
      "Bash(chmod +x*)",

      "Bash(cd * && python -m pytest *)",
      "Bash(cd * && python -m pytest*)",
      "Bash(pip install *)",
      "Bash(pip list*)",
      "Bash(pip show *)",
      "Bash(uv add *)",
      "Bash(uv pip install *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(git clean -f *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-safe-command.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/autoformat-python.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-imports.sh",
            "timeout": 20
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "preferredLanguage": "ru",
  "statusLine": {
    "type": "command",
    "command": "printf 'branch: %s | ollama: %s' \"$(git branch --show-current 2>/dev/null)\" \"$(curl -s --max-time 1 http://localhost:11434/ 2>/dev/null | grep -q running && echo UP || echo DOWN)\""
  }
}
