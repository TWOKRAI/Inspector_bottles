  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}\"/.claude/plugins/core/hooks/session-health-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}\"/.claude/plugins/core/hooks/session-plan-status.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}\"/.claude/plugins/core/hooks/session-project-map.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}\"/.claude/plugins/core/hooks/mcp-health-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}\"/.claude/plugins/core/hooks/session-memory-banner.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}\"/.claude/plugins/core/hooks/validate-safe-command.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}\"/.claude/plugins/core/hooks/protect-branch.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}\"/.claude/plugins/core/hooks/protect-readonly.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}\"/.claude/plugins/mcp-sentrux/hooks/sentrux-precheck.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}\"/.claude/plugins/core/hooks/filter-test-output.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}\"/.claude/plugins/lang-python/hooks/autoformat-python.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}\"/.claude/plugins/lang-python/hooks/check-imports.sh",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}\"/.claude/plugins/lang-python/hooks/typecheck-changed.sh",
            "timeout": 35
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}\"/.claude/plugins/core/hooks/precompact-context-save.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}\"/.claude/plugins/core/hooks/restore-context.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "env": {
    "MCP_TIMEOUT": "7200000",
    "MCP_TOOL_TIMEOUT": "7200000",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "statusLine": {
    "type": "command",
    "command": "printf 'branch: %s | ollama: %s' \"$(git branch --show-current 2>/dev/null)\" \"$(curl -s --max-time 1 http://localhost:11434/ 2>/dev/null | grep -q running && echo UP || echo DOWN)\""
  },
  "alwaysThinkingEnabled": true,
  "preferredLanguage": "ru",
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "sentry@claude-plugins-official": true
  }
